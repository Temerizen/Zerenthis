{
  "auto_apply_paths": [
    "backend/Engine/product_engine.py",
    "backend/Engine/video_engine.py",
    "backend/self_improve/"
  ],
  "approval_required_paths": [
    "backend/app/main.py",
    "index.html",
    "backend/requirements.txt",
    "backend/Procfile",
    "backend/nixpacks.toml"
  ],
  "forbidden_paths": [
    ".env",
    "secrets",
    "auth",
    "billing",
    ".git",
    "venv",
    "__pycache__"
  ],
  "max_patch_lines": 300,
  "loop_interval_seconds": 60
}
