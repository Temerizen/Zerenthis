from pathlib import Path
import uuid
import re
from typing import Dict

from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, PageBreak, Table, TableStyle
from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
from reportlab.lib.pagesizes import letter
from reportlab.lib import colors
from reportlab.lib.units import inch

BASE_DIR = Path(__file__).resolve().parents[1]
OUT_DIR = BASE_DIR / "data" / "outputs"
OUT_DIR.mkdir(parents=True, exist_ok=True)


def _clean(text, fallback=""):
    text = (text or "").strip()
    return text if text else fallback


def _safe_filename(text):
    text = re.sub(r"[^a-zA-Z0-9]+", "_", text).strip("_")
    return text or "zerenthis_product"


def _title_case(text):
    return " ".join(word.capitalize() for word in text.split())


def _premium_title(topic, promise):
    topic_tc = _title_case(_clean(topic, "Digital Product"))
    promise = _clean(promise)
    if promise:
        return f"{topic_tc} Execution Pack for {promise}"
    return f"{topic_tc} Execution Pack"


def _offer_ideas(topic, buyer, promise):
    topic = _clean(topic, "digital product")
    topic_tc = _title_case(topic)
    buyer_text = _clean(buyer, "Beginners")
    buyer_lower = buyer_text.lower()
    promise_text = _clean(promise, f"get better results with {topic}")
    return [
        {
            "name": f"{topic_tc} Starter Kit",
            "price": "$9–$19",
            "title": f"The {topic_tc} Starter Kit",
            "description": f"A beginner-friendly pack for {buyer_lower} who want to {promise_text}. Includes quick-start steps, templates, prompts, and a low-friction launch path.",
            "best_for": "First-time buyers who want speed and clarity",
            "cta": "Start with the entry offer and add a fast-action bonus"
        },
        {
            "name": f"{topic_tc} Premium Blueprint",
            "price": "$19–$29",
            "title": f"{topic_tc} Premium Blueprint",
            "description": f"A deeper system with examples, pricing ideas, execution checklists, and copy-paste assets for buyers who want faster and cleaner progress.",
            "best_for": "Buyers who want a fuller implementation system",
            "cta": "Position as the most complete done-with-you roadmap"
        },
        {
            "name": f"{topic_tc} Prompt Pack",
            "price": "$7–$17",
            "title": f"{topic_tc} Prompt Vault",
            "description": f"A focused library of prompts, templates, and workflows designed to reduce thinking time and increase implementation speed.",
            "best_for": "Action-takers who value templates over theory",
            "cta": "Use as an impulse buy, bump, or bundle enhancer"
        },
        {
            "name": f"{topic_tc} Fast-Start Pack",
            "price": "$9–$19",
            "title": f"{topic_tc} Fast-Start Pack",
            "description": f"An action-first pack built for overwhelmed beginners who need clarity, momentum, and a simple path to their first result.",
            "best_for": "New buyers who need immediate momentum",
            "cta": "Sell the transformation of fast clarity, not just pages"
        },
        {
            "name": f"{topic_tc} Bundle",
            "price": "$29–$49",
            "title": f"The Complete {topic_tc} Bundle",
            "description": f"A premium bundled offer combining guide, prompts, templates, and bonus assets into a stronger high-value package.",
            "best_for": "Customers already convinced and ready to spend more",
            "cta": "Anchor against buying each asset separately"
        },
    ]


def _prompt_bank(topic, niche, buyer, promise):
    topic = _clean(topic, "digital products")
    niche = _clean(niche, "online business")
    buyer_text = _clean(buyer, "beginners").lower()
    promise_text = _clean(promise, f"make progress with {topic}")
    return [
        f'Create a premium digital product about {topic} for {buyer_text} in the {niche} niche.',
        f'Write 10 high-converting Gumroad product titles for {topic}.',
        f'Generate 25 practical prompts someone can use to {promise_text}.',
        f'Create a 7-day action plan for a beginner trying to succeed with {topic}.',
        f'Write a Gumroad description that makes {topic} feel actionable and worth paying for.',
        f'List 10 bundle ideas related to {topic} that can increase average order value.',
        f'Create 5 short-form content ideas that promote a {topic} digital product.',
        f'Create 3 value-stack versions of a {topic} offer with pricing anchors and bonus ideas.',
        f'Write a short checkout page section that explains why this {topic} pack saves time for {buyer_text}.',
    ]


def _launch_plan(topic):
    return [
        ["Day 1", f"Generate 3 product variations around {topic}."],
        ["Day 2", "Pick the strongest one and upload it to Gumroad."],
        ["Day 3", "Create 3 short-form promo posts or scripts."],
        ["Day 4", "Improve the listing title, thumbnail, and description."],
        ["Day 5", "Create a second product using the same niche."],
        ["Day 6", "Bundle two products together for a higher-priced offer."],
        ["Day 7", "Double down on the best-performing angle and repeat."],
    ]


def _distribution_ideas(topic):
    return [
        f"Short-form videos about {topic} with a CTA to your product",
        f"Reddit discussion posts around pain points in {topic}",
        "X/Twitter threads that summarize one useful idea from the pack",
        "A free mini-post that leads into the paid version",
        "Bundle promotions and launch discounts",
        "Email your audience with a 48-hour fast-action bonus",
        "Use a simple lead magnet that upsells into the full pack",
    ]


def _monetization_summary(topic, buyer, promise):
    topic_text = _clean(topic, "digital product")
    buyer_text = _clean(buyer, "beginners")
    promise_text = _clean(promise, f"get results with {topic_text}")
 

def _score_product_pack(topic, buyer, promise, bonus, notes):
    checks = {
        "has_topic": bool(_clean(topic)),
        "has_buyer": bool(_clean(buyer)),
        "has_promise": bool(_clean(promise)),
        "has_bonus": bool(_clean(bonus)),
        "has_notes": bool(_clean(notes)),
    }
    score = int(sum(1 for passed in checks.values() if passed) / len(checks) * 100)
    return {"score": score, "checks": checks}
   return {
        "positioning": f"Sell this as a practical shortcut for {buyer_text} who want to {promise_text} without wasting time.",
        "price_strategy": "Lead with an entry offer, then upsell a premium bundle with templates and bonus assets.",
        "bundle_strategy": f"Bundle the core {topic_text} guide with prompts, checklists, and a fast-start bonus to raise perceived value.",
        "cta": "Use urgency, clarity, and a transformation-focused promise instead of generic feature lists.",
    }


def _score_product_pack(topic, buyer, promise, bonus, notes):
    checks = {
        "has_specific_topic": len(_clean(topic)) >= 4,
        "has_defined_buyer": len(_clean(buyer)) >= 6,
        "has_promise": bool(_clean(promise)),
        "has_bonus": bool(_clean(bonus)),
        "has_notes": bool(_clean(notes)),
    }
    score = int(sum(1 for passed in checks.values() if passed) / len(checks) * 100)
    return {"score": score, "checks": checks}
   return {
        "entry_offer": f"Low-ticket starter pack for {buyer_text.lower()}",
        "core_offer": f"Execution blueprint helping customers {promise_text}",
        "upsell": f"Bundle, prompt vault, or premium implementation pack around {topic_text}",
        "lead_magnet": f"Free checklist or mini-guide about {topic_text}",
    }


