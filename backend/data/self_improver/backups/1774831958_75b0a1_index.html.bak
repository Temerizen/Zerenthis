<!DOCTYPE html>
<html>
<head>
  <title>Zerenthis Founder Empire Panel</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { background:#05070d; color:white; font-family:Arial,sans-serif; padding:20px; }
    h1 { color:#00e5ff; text-align:center; margin-bottom:8px; }
    .sub { text-align:center; opacity:0.75; margin-bottom:10px; }
    .section { margin-bottom:24px; padding:16px; background:#0c1018; border-radius:14px; }
    input, select { width:100%; padding:12px; margin-bottom:10px; border-radius:10px; border:none; background:#111827; color:white; }
    button { padding:10px 14px; margin:4px; border-radius:10px; border:none; font-weight:bold; cursor:pointer; }
    .primary { background:#00e5ff; color:black; }
    .approve { background:#00ff88; color:black; }
    .reject { background:#ff4d4d; color:white; }
    .execute { background:#facc15; color:black; }
    .card { background:#111827; padding:14px; margin-bottom:12px; border-radius:12px; }
    pre { background:#000; padding:10px; border-radius:8px; overflow-x:auto; white-space:pre-wrap; }
    a { color:#8be9fd; }
  </style>
</head>
<body>
  <h1>🧠 Zerenthis Founder Empire Panel</h1>
  <div class="sub">Generate assets, review proposals, and monitor applied or failed changes.</div><div class="sub">Approval rate, quality signals, and recent outputs now guide your founder decisions.</div>
  <div class="sub">Empire mode is active: leverage compounds through offers, niches, trend pressure, and operator reflection.</div>

  <div class="section">
    <h2>Generate</h2>
    <input id="topic" placeholder="Topic" value="How to make money with AI in 2026">
    <select id="mode">
      <option value="product">Product Pack</option>
      <option value="shorts">Shorts Pack</option>
      <option value="youtube">YouTube Pack</option>
    </select>
    <button class="primary" onclick="generate()">Generate</button>
    <pre id="latestResult"></pre>
  </div>

  <div class="section">
    <h2>Founder Magic</h2>
    <pre id="magic"></pre>
  </div>

  <div class="section">
    <h2>Empire State</h2>
    <pre id="empire"></pre>
  </div>

  <div class="section">
    <h2>Pending Proposals</h2>
    <div id="proposals"></div>
  </div>

  <div class="section">
    <h2>Applied</h2>
    <div id="applied"></div>
  </div>

  <div class="section">
    <h2>Failed</h2>
    <div id="failed"></div>
  </div>

  <div class="section">
    <h2>Gallery</h2>
    <div id="gallery"></div>
  </div>

<script>
const API = "http://127.0.0.1:8000";

async function fetchJson(url, options = {}) {
  const res = await fetch(url, options);
  return await res.json();
}

function proposalCard(p) {
  const policy = (p.meta && p.meta.policy) ? p.meta.policy : {};
  return `
    <div class="card">
      <div><strong>${p.title}</strong></div>
      <div style="opacity:.8;margin:8px 0;">${p.reason}</div>
      <div style="opacity:.7;margin-bottom:8px;">Tier: ${policy.tier || "unknown"} | Risk: ${policy.risk_score ?? "?"}</div>
      <pre>${JSON.stringify(p.steps, null, 2)}</pre>
      <button class="approve" onclick="approveProposal('${p.id}')">Approve</button>
      <button class="reject" onclick="rejectProposal('${p.id}')">Reject</button>
      <button class="execute" onclick="executeProposal('${p.id}')">Execute</button>
    </div>
  `;
}

function simpleCard(p) {
  return `
    <div class="card">
      <div><strong>${p.title || p.id || "Item"}</strong></div>
      <div style="opacity:.8;margin:8px 0;">${p.reason || p.error || ""}</div>
      <div style="opacity:.7;">Status: ${p.status || "unknown"}</div>
    </div>
  `;
}

async function loadAll() {
  const pending = await fetchJson(`${API}/api/self-improver/proposals`);
  const applied = await fetchJson(`${API}/api/self-improver/applied`);
  const failed = await fetchJson(`${API}/api/self-improver/failed`);
  const gallery = await fetchJson(`${API}/api/gallery`);
  const magic = await fetchJson(`${API}/api/founder/magic`);
  const empire = await fetchJson(`${API}/api/empire/state`);

  document.getElementById("magic").textContent = JSON.stringify(magic, null, 2);
  document.getElementById("empire").textContent = JSON.stringify(empire, null, 2);

  document.getElementById("proposals").innerHTML = (pending.items || []).length
    ? pending.items.map(proposalCard).join("")
    : "<div class='card'>No pending proposals.</div>";

  document.getElementById("applied").innerHTML = (applied.items || []).length
    ? applied.items.slice(-10).reverse().map(simpleCard).join("")
    : "<div class='card'>No applied proposals yet.</div>";

  document.getElementById("failed").innerHTML = (failed.items || []).length
    ? failed.items.slice(-10).reverse().map(simpleCard).join("")
    : "<div class='card'>No failed proposals.</div>";

  document.getElementById("gallery").innerHTML = (gallery.items || []).length
    ? gallery.items.map(item => `
        <div class="card">
          <a href="${API}${item.url}" target="_blank">${item.name}</a>
          <div style="opacity:.7;">${item.extension} • ${Math.round(item.size_bytes / 1024)} KB</div>
        </div>
      `).join("")
    : "<div class='card'>No files yet.</div>";
}

async function approveProposal(id) {
  await fetchJson(`${API}/api/self-improver/approve/${id}`, { method: "POST" });
  loadAll();
}

async function rejectProposal(id) {
  await fetchJson(`${API}/api/self-improver/reject/${id}`, { method: "POST" });
  loadAll();
}

async function executeProposal(id) {
  await fetchJson(`${API}/api/self-improver/execute/${id}`, { method: "POST" });
  loadAll();
}

async function generate() {
  const topic = document.getElementById("topic").value.trim();
  const mode = document.getElementById("mode").value;
  let endpoint = "/api/product-pack";
  if (mode === "shorts") endpoint = "/api/shorts-pack";
  if (mode === "youtube") endpoint = "/api/youtube-pack";

  const payload = {
    topic,
    niche: "Make Money Online",
    tone: "Premium",
    buyer: "Beginners starting from zero",
    promise: "get results faster",
    bonus: "templates and prompts",
    notes: "Keep it practical and premium",
    duration_seconds: 35
  };

  const data = await fetchJson(`${API}${endpoint}`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(payload)
  });

  document.getElementById("latestResult").textContent = JSON.stringify(data, null, 2);

  if (data.job_id) {
    setTimeout(loadAll, 2500);
    setTimeout(loadAll, 5000);
  } else {
    loadAll();
  }
}

loadAll();
setInterval(loadAll, 7000);
</script>
</body>
</html>
