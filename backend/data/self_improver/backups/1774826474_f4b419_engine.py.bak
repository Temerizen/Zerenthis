from __future__ import annotations
import json, time, shutil, uuid, hashlib
from pathlib import Path

ROOT = Path(__file__).resolve().parents[2]
DATA = ROOT / "backend" / "data" / "self_improver"
BACKUPS = DATA / "backups"
FILE = DATA / "proposals.json"
EXECUTION_LOG = DATA / "execution_log.json"

DATA.mkdir(parents=True, exist_ok=True)
BACKUPS.mkdir(parents=True, exist_ok=True)

PROTECTED = [".env", ".git", "node_modules", "venv", "backend/data"]
ALLOWED_ACTIONS = {"create_file", "edit_file", "delete_file"}
TEXT_FILE_SUFFIXES = {".py", ".tsx", ".ts", ".js", ".jsx", ".json", ".css", ".md", ".toml", ".yml", ".yaml", ".txt"}
HIGH_RISK_PATH_HINTS = ["main.py", "routes.py", "engine.py", "requirements.txt", "Procfile", "nixpacks.toml"]
MAX_TEXT_FIELD_LENGTH = 30000


def summarize_steps(steps):
    action_counts = {}
    touched_paths = []
    for step in steps:
        action = step.get("action", "unknown")
        action_counts[action] = action_counts.get(action, 0) + 1
        path = step.get("path")
        if isinstance(path, str):
            touched_paths.append(path)
    return {
        "step_count": len(steps),
        "action_counts": action_counts,
        "touched_paths": touched_paths,
    }


def assess_proposal_risk(steps):
    summary = summarize_steps(steps)
    touched_paths = summary["touched_paths"]
    reasons = []
    score = 0

    if summary["action_counts"].get("delete_file", 0) > 0:
        score += 35
        reasons.append("contains delete_file action")
    if summary["action_counts"].get("create_file", 0) > 0:
        score += 10
        reasons.append("contains create_file action")
    if summary["step_count"] >= 5:
        score += 15
        reasons.append("has 5 or more actions")

    high_risk_paths = [p for p in touched_paths if any(hint in p for hint in HIGH_RISK_PATH_HINTS)]
    if high_risk_paths:
        score += min(30, 10 * len(high_risk_paths))
        reasons.append("touches core runtime files")

    if any(p.endswith(".json") for p in touched_paths):
        score += 10
        reasons.append("touches json files")

    score = min(score, 100)
    if score >= 60:
        level = "high"
    elif score >= 25:
        level = "medium"
    else:
        level = "low"

    return {
        "score": score,
        "level": level,
        "reasons": reasons,
    }


def load():
    if not FILE.exists():
        return []
    return json.loads(FILE.read_text(encoding="utf-8"))


def save(d):
    temp = FILE.with_suffix(".tmp")
    temp.write_text(json.dumps(d, indent=2), encoding="utf-8")
    temp.replace(FILE)


def new_id():
    return f"prop_{int(time.time())}_{uuid.uuid4().hex[:6]}"


def _fingerprint(title, steps):
    payload = json.dumps({"title": title.strip(), "steps": steps}, sort_keys=True)
    return hashlib.sha256(payload.encode()).hexdigest()


def _load_execution_log():
    if not EXECUTION_LOG.exists():
        return []
    try:
        data = json.loads(EXECUTION_LOG.read_text(encoding="utf-8"))
        return data if isinstance(data, list) else []
    except Exception:
        return []


def _save_execution_log(items):
    temp = EXECUTION_LOG.with_suffix(".tmp")
    temp.write_text(json.dumps(items, indent=2), encoding="utf-8")
    temp.replace(EXECUTION_LOG)


def validate_proposal_payload(title, reason, steps):
    if not isinstance(title, str) or len(title.strip()) < 5:
        raise ValueError("title must be at least 5 characters")
    if not isinstance(reason, str) or len(reason.strip()) < 20:
        raise ValueError("reason must be at least 20 characters")
    lowered_title = title.strip().lower()
    blocked_title_phrases = ["test", "misc", "random", "quick fix", "stuff"]
    if any(phrase == lowered_title for phrase in blocked_title_phrases):
        raise ValueError("title is too low-signal")

    _validate_steps(steps)

    summary = summarize_steps(steps)
    touched = summary["touched_paths"]
    if len(touched) != len(set(touched)):
        raise ValueError("proposal contains duplicate target paths")

    title_fp = _fingerprint(title, steps)
    for item in load():
        if _fingerprint(item.get("title", ""), item.get("steps", [])) == title_fp:
            raise ValueError("duplicate proposal already exists")

    risk = assess_proposal_risk(steps)
    if risk["level"] == "high":
        raise ValueError("proposal risk is too high for automatic intake")

    return {
        "summary": summary,
        "risk": risk,
        "fingerprint": title_fp,
    }


def _validate_steps(steps):
    if not isinstance(steps, list) or not steps:
        raise ValueError("steps must be a non-empty list")
    if len(steps) > 10:
        raise ValueError("steps cannot exceed 10 actions")

    touched_paths = {}

    for i, step in enumerate(steps):
        if not isinstance(step, dict):
            raise ValueError(f"step {i} must be an object")

        action = step.get("action")
        path = step.get("path")

        if action not in ALLOWED_ACTIONS:
            raise ValueError(f"step {i} has invalid action")
        if not isinstance(path, str) or not path.strip():
            raise ValueError(f"step {i} path is required")
        if len(path.strip()) > 300:
            raise ValueError(f"step {i} path is too long")
        if any(x in path for x in PROTECTED) or path.startswith("/") or path.startswith("\\") or ".." in path:
            raise ValueError(f"step {i} path is blocked")

        normalized_path = path.strip()
        previous_action = touched_paths.get(normalized_path)
        if previous_action is not None:
            raise ValueError(f"step {i} reuses path already targeted earlier: {normalized_path}")
        touched_paths[normalized_path] = action

        suffix = Path(path).suffix.lower()
        if suffix and suffix not in TEXT_FILE_SUFFIXES:
            raise ValueError(f"step {i} file type is not allowed")

        if action == "delete_file" and suffix == ".json":
            raise ValueError(f"step {i} cannot delete json data files")

        if action == "edit_file":
            find_text = step.get("find")
            replace_text = step.get("replace")
            if not isinstance(find_text, str) or not find_text:
                raise ValueError(f"step {i} edit_file requires non-empty find text")
            if not isinstance(replace_text, str):
                raise ValueError(f"step {i} edit_file requires replace text")
            if len(find_text) > MAX_TEXT_FIELD_LENGTH or len(replace_text) > MAX_TEXT_FIELD_LENGTH:
                raise ValueError(f"step {i} edit_file payload is too large")
            if find_text == replace_text:
                raise ValueError(f"step {i} edit_file find and replace cannot be identical")

        if action == "create_file":
            content = step.get("content")
            if not isinstance(content, str) or not content.strip():
                raise ValueError(f"step {i} create_file requires non-empty content")
            if len(content) > MAX_TEXT_FIELD_LENGTH:
                raise ValueError(f"step {i} create_file content is too large")

        if action == "delete_file":
            extra_keys = {"find", "replace", "content"}.intersection(step.keys())
            if extra_keys:
                raise ValueError(f"step {i} delete_file cannot include content fields")

        if action == "create_file":
            if "content" not in step or not isinstance(step.get("content"), str):
                raise ValueError(f"step {i} create_file requires string content")
            if len(step.get("content", "")) > 200000:
                raise ValueError(f"step {i} create_file content is too large")

        if action == "edit_file":
            if not isinstance(step.get("find"), str) or not step.get("find"):
                raise ValueError(f"step {i} edit_file requires non-empty find text")
            if not isinstance(step.get("replace"), str):
                raise ValueError(f"step {i} edit_file requires string replace text")
            if step.get("find") == step.get("replace"):
                raise ValueError(f"step {i} edit_file find and replace cannot be identical")
            if len(step.get("find", "")) > 20000 or len(step.get("replace", "")) > 200000:
                raise ValueError(f"step {i} edit_file payload is too large")

            target_path = ROOT / normalized_path
            if not target_path.exists():
                raise ValueError(f"step {i} edit target does not exist: {normalized_path}")
            try:
                original = target_path.read_text(encoding="utf-8")
            except UnicodeDecodeError:
                raise ValueError(f"step {i} edit target is not a valid utf-8 text file: {normalized_path}")
            except Exception as e:
                raise ValueError(f"step {i} could not read edit target: {normalized_path} ({e})")
            occurrences = original.count(step.get("find"))
            if occurrences == 0:
                raise ValueError(f"step {i} find text does not exist in file: {normalized_path}")
            if occurrences > 1:
                raise ValueError(f"step {i} find text must match exactly once in file: {normalized_path}")
            if step.get("find", "").strip() != step.get("find", ""):
                raise ValueError(f"step {i} edit_file find text cannot have trimmed leading or trailing whitespace")


def propose(title, reason, steps):
    if not isinstance(title, str) or not title.strip():
        raise ValueError("title is required")
    if not isinstance(reason, str) or len(reason.strip()) < 10:
        raise ValueError("reason must be at least 10 characters")
    _validate_steps(steps)
    title = title.strip()
    reason = reason.strip()
    d = load()
    fingerprint = _fingerprint(title, steps)

    for existing in d:
        if existing.get("fingerprint") == fingerprint and existing.get("status") in {"pending", "approved", "applied"}:
            return existing

    p = {
        "id": new_id(),
        "title": title,
        "reason": reason,
        "steps": steps,
        "status": "pending",
        "fingerprint": fingerprint,
        "created_at": int(time.time()),
        "summary": summarize_steps(steps),
        "risk": assess_proposal_risk(steps)
    }
    d.append(p)
    save(d)
    return p


def pending():
    return [x for x in load() if x.get("status") == "pending"]


def approve(pid):
    d = load()
    found = False
    for x in d:
        if x["id"] == pid:
            _validate_steps(x.get("steps", []))
            x["status"] = "approved"
            found = True
    save(d)
    return found


def reject(pid):
    d = load()
    found = False
    for x in d:
        if x["id"] == pid:
            x["status"] = "rejected"
            found = True
    save(d)
    return found


def pending():
    return [x for x in load() if x.get("status") == "pending"]


def backup(path):
    if not path.exists():
        return None
    b = BACKUPS / f"{int(time.time())}_{uuid.uuid4().hex[:6]}_{path.name}.bak"
    shutil.copy2(path, b)
    return b


def execute(pid):
    d = load()
    p = next((x for x in d if x["id"] == pid), None)

    if not p:
        return {"ok": False, "error": "proposal not found"}
    if p["status"] != "approved":
        return {"ok": False, "error": "not approved"}

    _validate_steps(p["steps"])
    backups = []
    created_files = []
    execution_log = _load_execution_log()
    started_at = int(time.time())

    try:
        for s in p["steps"]:
            path = ROOT / s["path"]

            if s["action"] == "create_file":
                path.parent.mkdir(parents=True, exist_ok=True)
                if path.exists():
                    raise Exception(f"refusing to overwrite existing file: {s['path']}")
                path.write_text(s.get("content", ""), encoding="utf-8")
                created_files.append(path)

            elif s["action"] == "edit_file":
                if not path.exists():
                    raise Exception(f"missing file: {s['path']}")
                b = backup(path)
                if b:
                    backups.append((path, b))
                txt = path.read_text(encoding="utf-8")
                if s["find"] not in txt:
                    raise Exception(f"find text not found in {s['path']}")
                txt = txt.replace(s["find"], s["replace"], 1)
                path.write_text(txt, encoding="utf-8")

            elif s["action"] == "delete_file":
                if not path.exists():
                    raise Exception(f"missing file: {s['path']}")
                b = backup(path)
                if b:
                    backups.append((path, b))
                path.unlink()

        p["status"] = "applied"
        p["applied_at"] = int(time.time())
        save(d)
        result = {
            "ok": True,
            "id": pid,
            "status": "applied",
            "applied_steps": len(p.get("steps", [])),
            "backups_created": len(backups),
        }
        execution_log.append({
            "id": pid,
            "title": p.get("title"),
            "status": "applied",
            "started_at": started_at,
            "finished_at": int(time.time()),
            "steps": p.get("steps", []),
            "result": result,
        })
        _save_execution_log(execution_log)
        return result
    except Exception as e:
        for path, bak in reversed(backups):
            shutil.copy2(bak, path)
        for path in reversed(created_files):
            if path.exists():
                path.unlink()

        p["status"] = "failed"
        p["failed_at"] = int(time.time())
        p["last_error"] = str(e)
        save(d)
        result = {"ok": False, "error": str(e), "id": pid, "status": "failed"}
        execution_log.append({
            "id": pid,
            "title": p.get("title"),
            "status": "failed",
            "started_at": started_at,
            "finished_at": int(time.time()),
            "steps": p.get("steps", []),
            "error": str(e),
        })
        _save_execution_log(execution_log)
        return resultturn {"ok": True, "id": pid}

    except Exception as e:
        for orig, b in backups:
            shutil.copy2(b, orig)
        p["status"] = "failed"
        p["failed_at"] = int(time.time())
        p["error"] = str(e)
        save(d)
        execution_log.append({
            "id": pid,
            "title": p.get("title"),
            "status": "failed",
            "started_at": started_at,
            "finished_at": int(time.time()),
            "error": str(e),
            "steps": p.get("steps", [])
        })
        _save_execution_log(execution_log)
        return {"ok": False, "error": str(e)}n_log.append({
            "id": pid,
            "title": p.get("title"),
            "status": "failed",
            "started_at": started_at,
            "finished_at": int(time.time()),
            "error": str(e),
            "steps": p.get("steps", [])
        })
        _save_execution_log(execution_log)
