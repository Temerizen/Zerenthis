# =========================
# 📊 JOB SYSTEM
# =========================

@app.get("/api/job/{job_id}")
def job_status(job_id: str):
    data = get_job(job_id)
    if data.get("status") == "not_found":
        raise HTTPException(status_code=404, detail="Job not found")
    return data


# =========================
# 📁 FILE SERVING
# =========================

@app.get("/api/file/{name}")
def serve_file(name: str):
    if "/" in name or "\\" in name:
        raise HTTPException(status_code=400, detail="Invalid file name")

    path = OUTPUT_DIR / name
    if not path.exists() or not path.is_file():
        raise HTTPException(status_code=404, detail="File missing")

    media_type = "application/octet-stream"
    suffix = path.suffix.lower()
    if suffix == ".pdf":
        media_type = "application/pdf"
    elif suffix == ".mp4":
        media_type = "video/mp4"
    elif suffix == ".png":
        media_type = "image/png"
    elif suffix == ".jpg" or suffix == ".jpeg":
        media_type = "image/jpeg"
    elif suffix == ".txt":
        media_type = "text/plain; charset=utf-8"

    return FileResponse(
        path=str(path),
        media_type=media_type,
        filename=quote(path.name),
    )


@app.get("/api/outputs")
def list_outputs():
    files = []
    for path in sorted(OUTPUT_DIR.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True):
        if not path.is_file():
            continue
        files.append(
            {
                "name": path.name,
                "size": path.stat().st_size,
                "url": f"{get_base_url()}/api/file/{quote(path.name)}",
            }
        )
    return {"items": files, "count": len(files)}
    elif path.suffix.lower() == ".mp4":
        media_type = "video/mp4"
    elif path.suffix.lower() == ".png":
        media_type = "image/png"

    return FileResponse(path, media_type=media_type, filename=path.name)


@app.get("/api/gallery")
def gallery():
    items = []
    for path in sorted(OUTPUT_DIR.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True):
        if not path.is_file():
            continue

        items.append(
            {
                "name": path.name,
                "size_bytes": path.stat().st_size,
                "modified_ts": path.stat().st_mtime,
                "download_url": f"{get_base_url()}/api/file/{quote(path.name)}",
                "url": f"/api/file/{path.name}",
                "extension": path.suffix.lower(),
            }
        )

    return {"items": items[:200]}