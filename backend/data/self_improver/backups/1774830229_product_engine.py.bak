from __future__ import annotations

import uuid
from pathlib import Path
from reportlab.lib.pagesizes import letter
from reportlab.pdfgen import canvas

OUTPUT_DIR = Path(__file__).resolve().parents[1] / "data" / "outputs"
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

def _make_pdf(title: str, content: str, filename: str) -> str:
    path = OUTPUT_DIR / filename
    c = canvas.Canvas(str(path), pagesize=letter)

    y = 750
    c.setFont("Helvetica-Bold", 16)
    c.drawString(50, y, title)

    y -= 40
    c.setFont("Helvetica", 11)

    for line in content.split("\n"):
        if y < 50:
            c.showPage()
            c.setFont("Helvetica", 11)
            y = 750
        c.drawString(50, y, line[:100])
        y -= 15

    c.save()
    return filename

def build_product_pack(
    topic: str,
    niche: str,
    tone: str,
    buyer: str,
    promise: str = "",
    bonus: str = "",
    notes: str = "",
    base_url: str = "",
):
    topic_text = (topic or "Digital Product").strip()
    niche_text = (niche or "General").strip()
    tone_text = (tone or "Premium").strip()
    buyer_text = (buyer or "Beginners").strip()
    promise_text = (promise or f"get better results with {topic_text}").strip()
    bonus_text = (bonus or f"{topic_text.title()} Quick-Start Bonus").strip()
    notes_text = (notes or "None provided").strip()

    title = f"{topic_text.title()} Execution Pack"
    front_end_price = 19
    order_bump_price = 9
    upsell_price = 29
    anchor_price = 79
    savings_vs_anchor = anchor_price - upsell_price
    recommended_offer = "bundle" if len((promise_text or "").split()) >= 5 else "front_end"

    file_url_preview = f"{base_url}/api/file" if base_url else "/api/file"

    content = f"""
{title}

CORE POSITIONING
Topic: {topic_text}
Niche: {niche_text}
Tone: {tone_text}
Target Buyer: {buyer_text}
Primary Promise: {promise_text}

OFFER STACK
1. Front-End Offer: {title} - ${front_end_price}
2. Order Bump: {bonus_text} - ${order_bump_price}
3. Upsell: {topic_text.title()} Bundle - ${upsell_price}
4. Value Anchor: Comparable consulting-style value - ${anchor_price}

WHY THIS SELLS
- Clear outcome for a specific buyer
- Fast-start execution instead of vague theory
- Low-ticket entry with natural value ladder
- Bonus and upsell increase average order value
- Value anchoring makes the bundle feel easier to justify

CHECKOUT COPY
- Order Bump Prompt: Add {bonus_text} now so you can implement faster without creating everything from scratch.
- Upsell Prompt: Upgrade to the full {topic_text.title()} Bundle and save ${savings_vs_anchor} versus the anchored value.
- Recommended Starting Offer: {recommended_offer}

PRODUCT DELIVERABLES
- Core execution guide
- Action checklist
- 7-day implementation sprint
- Simple promotion plan
- CTA copy starter

QUICK SALES COPY
Headline: {title} for {buyer_text}
Subheadline: A simple system to help you {promise_text} without wasting time on scattered tactics.
CTA: Start with the front-end offer, add the bonus, and upgrade if you want the full bundle.

LAUNCH PLAN
1. Identify one urgent pain point in {niche_text}
2. Position this pack as the simple path to {promise_text}
3. Use short-form content to drive curiosity
4. Send traffic to the product page with one core CTA
5. Offer the bonus at checkout to raise cart value
6. Present the bundle as the next logical upgrade

CONTENT ANGLES
- Common mistakes beginners make with {topic_text}
- The faster path to {promise_text}
- What to do first if you are starting from zero
- A simple framework for consistent execution

FOUNDER NOTES
{notes_text}

DELIVERY
Generated file endpoint: {file_url_preview}
"""

    filename = f"{topic_text.replace(' ', '_')}_{uuid.uuid4().hex[:6]}.pdf"
    _make_pdf(title, content, filename)

    file_url = f"{base_url}/api/file/{filename}" if base_url else f"/api/file/{filename}"

    return {
        "title": title,
        "file_name": filename,
        "file_url": file_url,
        "offer": {
            "front_end": {"name": title, "price": front_end_price},
            "order_bump": {"name": bonus_text, "price": order_bump_price},
            "upsell": {"name": f"{topic_text.title()} Bundle", "price": upsell_price},
            "anchor": {"name": "Comparable consulting-style value", "price": anchor_price},
            "recommended_offer": recommended_offer,
            "savings_vs_anchor": savings_vs_anchor,
        },
        "summary": {
            "buyer": buyer_text,
            "promise": promise_text,
            "cta": "Start with the front-end offer, add the bonus, and upgrade to the bundle.",
            "order_bump_copy": f"Add {bonus_text} now so you can implement faster without creating everything from scratch.",
            "upsell_copy": f"Upgrade to the full {topic_text.title()} Bundle and save ${savings_vs_anchor} versus the anchored value.",
        },
    }

def build_product_batch(**kwargs):
    count = kwargs.get("count", 3)
    count = max(1, min(int(count or 3), 10))

    topic = (kwargs.get("topic") or "Digital Product").strip()
    niche = (kwargs.get("niche") or "General").strip()
    tone = (kwargs.get("tone") or "Premium").strip()
    buyer = (kwargs.get("buyer") or "Beginners").strip()
    promise = (kwargs.get("promise") or "").strip()
    bonus = (kwargs.get("bonus") or "").strip()
    notes = (kwargs.get("notes") or "").strip()
    base_url = (kwargs.get("base_url") or "").strip()

    angle_templates = [
        {
            "suffix": "Starter",
            "promise": promise or f"build momentum with {topic}",
            "bonus": bonus or f"{topic.title()} Quick-Start Bonus",
            "notes": notes or "Designed for speed and simplicity.",
        },
        {
            "suffix": "Conversion",
            "promise": promise or f"turn {topic} into a clearer result faster",
            "bonus": bonus or f"{topic.title()} Swipe File",
            "notes": notes or "Positioned for buyers who want implementation support.",
        },
        {
            "suffix": "Premium",
            "promise": promise or f"create a premium system around {topic}",
            "bonus": bonus or f"{topic.title()} Templates Pack",
            "notes": notes or "Framed as the higher-perceived-value version.",
        },
        {
            "suffix": "Fast-Track",
            "promise": promise or f"get faster wins with {topic}",
            "bonus": bonus or f"{topic.title()} Action Checklist",
            "notes": notes or "Best for action-oriented entry offers.",
        },
        {
            "suffix": "Authority",
            "promise": promise or f"build trust and results with {topic}",
            "bonus": bonus or f"{topic.title()} Authority Booster",
            "notes": notes or "Useful when selling expertise-driven positioning.",
        },
    ]

    items = []
    for i in range(count):
        angle = angle_templates[i % len(angle_templates)]
        variant_topic = f"{topic} {angle['suffix']}"
        pack = build_product_pack(
            topic=variant_topic,
            niche=niche,
            tone=tone,
            buyer=buyer,
            promise=angle["promise"],
            bonus=angle["bonus"],
            notes=angle["notes"],
            base_url=base_url,
        )
        items.append(
            {
                "index": i + 1,
                "angle": angle["suffix"].lower(),
                "title": pack["title"],
                "file_name": pack["file_name"],
                "file_url": pack["file_url"],
                "offer": pack["offer"],
                "summary": pack["summary"],
            }
        )

    return {
        "count": len(items),
        "topic": topic,
        "niche": niche,
        "buyer": buyer,
        "items": items,
    }0))

    results = []
    base_topic = (kwargs.get("topic") or "Digital Product").strip()

    for i in range(count):
        variant_kwargs = dict(kwargs)
        if count > 1:
            variant_kwargs["topic"] = f"{base_topic} Variant {i + 1}"
        else:
            variant_kwargs["topic"] = base_topic

        results.append(build_product_pack(**variant_kwargs))

    return {
        "count": count,
        "items": results,
    }
):
        results.append(build_product_pack(**kwargs))
    return results
