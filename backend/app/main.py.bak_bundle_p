@app.post("/api/full-loop/run")
def full_loop_run():
    outputs = {}

    try:
        from backend.app.engines.product_engine import run as product_run
        outputs["products"] = product_run()
    except Exception as e:
        outputs["products_error"] = str(e)

    try:
        from backend.app.engines.storefront_engine import run as storefront_run
        outputs["storefront"] = storefront_run()
    except Exception as e:
        outputs["storefront_error"] = str(e)

    try:
        from backend.app.engines.offer_engine import run as offer_run
        outputs["offers"] = offer_run()
    except Exception as e:
        outputs["offers_error"] = str(e)

    try:
        from backend.app.engines.traffic_engine import run as traffic_run
        outputs["traffic"] = traffic_run()
    except Exception as e:
        outputs["traffic_error"] = str(e)

    return {
        "status": "full_loop_executed",
        "outputs": outputs
    }


@app.post("/api/full-loop/revenue-run")
def api_full_loop_revenue_run():
    outputs = {}

    try:
        from backend.app.engines.product_engine import run as product_run
        outputs["products"] = product_run()
    except Exception as e:
        outputs["products_error"] = str(e)

    try:
        from backend.app.engines.storefront_engine import run as storefront_run
        outputs["storefront"] = storefront_run()
    except Exception as e:
        outputs["storefront_error"] = str(e)

    try:
        from backend.app.engines.offer_engine import run as offer_run
        outputs["offers"] = offer_run()
    except Exception as e:
        outputs["offers_error"] = str(e)

    try:
        from backend.app.engines.traffic_engine import run as traffic_run
        outputs["traffic"] = traffic_run()
    except Exception as e:
        outputs["traffic_error"] = str(e)

    try:
        from backend.app.engines.revenue_engine import record_result
        products_block = outputs.get("products", {})
        products = products_block.get("products", []) if isinstance(products_block, dict) else []
        outputs["revenue"] = record_result(products)
    except Exception as e:
        outputs["revenue_error"] = str(e)

    return {
        "status": "full_loop_revenue_executed",
        "outputs": outputs
    }


@app.get("/api/builder/winner-targets")
def api_builder_winner_targets():
    try:
        from backend.app.builder.winner_mapper import winner_to_targets
        return {
            "status": "ok",
            "targets": winner_to_targets()
        }
    except Exception as e:
        return {
            "status": "error",
            "error": str(e)
        }


@app.post("/api/run-winner-builder")
def api_run_winner_builder(payload: dict = Body(None)):
    payload = payload or {}
    data = payload.get("data", payload)

    try:
        from backend.app.builder.winner_mapper import winner_to_targets
        selected_targets = winner_to_targets()
    except Exception as e:
        return {
            "controller": "active",
            "task": "builder",
            "result": {
                "status": "winner_target_error",
                "error": str(e)
            }
        }

    plan = create_patch_plan(
        goal=data.get("goal", "Improve the strongest revenue pathway"),
        target=selected_targets,
        reason=data.get("reason", "winner_driven"),
        priority=data.get("priority", "high"),
    )
    result = apply_patch_plan(plan)
    feedback = log_builder_feedback(data, plan, result)

    return {
        "controller": "active",
        "task": "builder",
        "result": {
            "status": "winner_builder_executed",
            "selected_targets": selected_targets,
            "plan": plan,
            "apply_result": result,
            "feedback": feedback
        }
    }


