@app.post("/api/autopilot/handoff-builder")
def api_autopilot_handoff_builder():
    def _run_controller(payload: dict):
        task_type = payload.get("type")
        data = payload.get("data", {})

        if task_type == "builder":
            plan = create_patch_plan(
                goal=data.get("goal", "Safely improve module"),
                target=data.get("target"),
                reason=data.get("reason", ""),
                priority=data.get("priority", "medium"),
            )
            result = apply_patch_plan(plan)
            feedback = log_builder_feedback(data, plan, result)
            return {
                "controller": "active",
                "task": "builder",
                "result": {
                    "status": "builder_executed",
                    "plan": plan,
                    "apply_result": result,
                    "feedback": feedback
                }
            }

        return {
            "controller": "active",
            "task": task_type,
            "result": {
                "status": "unsupported_handoff_task",
                "data": data
            }
        }

    return execute_autopilot_builder_handoff(_run_controller)


@app.post("/api/autopilot/continuous-builder-loop")
def api_autopilot_continuous_builder_loop(payload: dict = Body(None)):
    payload = payload or {}
    max_cycles = int(payload.get("max_cycles", 5))
    delay_seconds = float(payload.get("delay_seconds", 1.0))

    def _run_controller(task_payload: dict):
        task_type = task_payload.get("type")
        data = task_payload.get("data", {})

        if task_type == "builder":
            plan = create_patch_plan(
                goal=data.get("goal", "Safely improve module"),
                target=data.get("target"),
                reason=data.get("reason", ""),
                priority=data.get("priority", "medium"),
            )
            result = apply_patch_plan(plan)
            feedback = log_builder_feedback(data, plan, result)
            return {
                "controller": "active",
                "task": "builder",
                "result": {
                    "status": "builder_executed",
                    "plan": plan,
                    "apply_result": result,
                    "feedback": feedback
                }
            }

        return {
            "controller": "active",
            "task": task_type,
            "result": {
                "status": "unsupported_loop_task",
                "data": data
            }
        }

    return run_continuous_builder_loop(
        run_controller=_run_controller,
        max_cycles=max_cycles,
        delay_seconds=delay_seconds
    )


@app.get("/api/autopilot/queue")
