@app.post("/api/full-loop/champion-run")
def api_full_loop_champion_run():
    outputs = {}

    try:
        from backend.app.engines.product_engine import run as product_run
        outputs["products"] = product_run()
    except Exception as e:
        outputs["products_error"] = str(e)

    try:
        from backend.app.engines.storefront_engine import run as storefront_run
        outputs["storefront"] = storefront_run()
    except Exception as e:
        outputs["storefront_error"] = str(e)

    try:
        from backend.app.engines.offer_engine import run as offer_run
        outputs["offers"] = offer_run()
    except Exception as e:
        outputs["offers_error"] = str(e)

    try:
        from backend.app.engines.traffic_engine import run as traffic_run
        outputs["traffic"] = traffic_run()
    except Exception as e:
        outputs["traffic_error"] = str(e)

    try:
        from backend.app.engines.variant_memory_engine import get_variant_winner
        outputs["champion_offer"] = get_variant_winner()
    except Exception as e:
        outputs["champion_offer_error"] = str(e)

    try:
        from backend.app.engines.revenue_engine import record_result

        products_block = outputs.get("products", {})
        products = products_block.get("products", []) if isinstance(products_block, dict) else []

        champion = outputs.get("champion_offer", {})
        if isinstance(champion, dict) and champion.get("name"):
            products = list(products) + [{
                "name": champion.get("name", "Champion Offer"),
                "price": champion.get("price", 0),
                "description": champion.get("headline", "")
            }]

        outputs["revenue"] = record_result(products)
    except Exception as e:
        outputs["revenue_error"] = str(e)

    return {
        "status": "full_loop_champion_executed",
        "outputs": outputs
    }


