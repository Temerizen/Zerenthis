@app.post("/api/run")
def api_run(payload: dict = Body(...)):
    task_type = payload.get("type")
    data = payload.get("data", {})

    if task_type == "builder":
        plan = create_patch_plan(
            goal=data.get("goal", "Safely improve module"),
            target=data.get("target"),
            reason=data.get("reason", ""),
            priority=data.get("priority", "medium"),
        )
        result = apply_patch_plan(plan)
        feedback = log_builder_feedback(data, plan, result)
        return {
            "controller": "active",
            "task": "builder",
            "result": {
                "status": "builder_executed",
                "plan": plan,
                "apply_result": result,
                "feedback": feedback
            }
        }

    if task_type == "autopilot":
        return {
            "controller": "active",
            "task": "autopilot",
            "result": {
                "status": "autopilot_live",
                "data": data
            }
        }

    if task_type == "agents":
        return {
            "controller": "active",
            "task": "agents",
            "result": {
                "status": "agent_swarm_ready",
                "data": data
            }
        }

    return {
        "controller": "active",
        "task": task_type,
        "result": {
            "status": "unknown_task",
            "data": data
        }
    }


