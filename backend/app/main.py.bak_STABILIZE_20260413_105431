from fastapi import FastAPI
from backend.app.cognition import (
    meta, world, explore, decision,
    execution, intent, goals, mission,
    reality, adaptation, strategy, status_engine,
    strategy_pressure, strategy_evolution, coherence_engine,
    self_correction_engine, autonomous_mission_engine
)
from backend.app.cognition.value_hierarchy import evaluate_values

app = FastAPI()

@app.get("/health")
def health():
    return {
        "brain": "online",
        "adaptive": True,
        "strategy": True,
        "coherence": True,
        "self_correction": True,
        "autonomous_mission": True
    }

def _brain_cycle():
    world.update({"tick": "loop"})
    meta.run({"event": "cycle"})
    explore.run()

    value_state = evaluate_values()

    intent_state = intent.form_intent({
        "value_state": value_state
    })

    decision_state = decision.run({
        "intent_state": intent_state
    })

    execution_state = execution.run({"plan": {}})

    goal_state = goals.run({
        "goal": intent_state.get("goal"),
        "dominant_value": value_state.get("dominant_value")
    })

    active_goal = goal_state.get("active_goal")

    mission_state = mission.run({
        "active_goal": active_goal
    }) if active_goal else {"active_mission": None, "status": "no_goal"}

    active_mission = mission_state.get("active_mission")

    reality_state = reality.run({
        "mission_id": active_mission.get("id") if active_mission else None,
        "goal_type": active_goal.get("type") if active_goal else None,
        "mission_progress": active_mission.get("progress") if active_mission else 0
    })

    score = reality_state.get("score", 0.5)

    adaptation_state = adaptation.run({
        "score": score,
        "goal": active_goal
    })

    strategy_state = strategy.run({
        "score": score
    })

    adjustment = adaptation_state.get("adjustment", {}) if adaptation_state else {}
    pressure_state = strategy_pressure.run({
        "strategy": strategy_state.get("strategy", "default"),
        "adjustment_action": adjustment.get("action", "neutral_adjust")
    })

    evolution_state = strategy_evolution.run({
        "score": score
    })

    coherence_state = coherence_engine.run()
    self_correction_state = self_correction_engine.run()
    autonomous_mission_state = autonomous_mission_engine.run()

    status_state = status_engine.run()

    return {
        "status": "ok",
        "goal_state": goal_state,
        "mission_state": mission_state,
        "reality_state": reality_state,
        "adaptation_state": adaptation_state,
        "strategy_state": strategy_state,
        "pressure_state": pressure_state,
        "evolution_state": evolution_state,
        "coherence_state": coherence_state,
        "self_correction_state": self_correction_state,
        "autonomous_mission_state": autonomous_mission_state,
        "status_state": status_state
    }

@app.post("/api/brain/run")
def brain():
    return _brain_cycle()

@app.get("/api/brain/status")
def brain_status():
    return status_engine.run()
