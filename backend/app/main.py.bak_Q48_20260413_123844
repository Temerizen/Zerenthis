from fastapi import FastAPI
from backend.app.cognition import (
    meta, world, explore, decision,
    execution, intent, goals, mission,
    reality, adaptation, strategy,
    coherence_engine, self_correction_engine,
    autonomous_mission_engine, initiative_engine,
    reasoning_engine, memory_depth_engine,
    strategic_adjustment_engine, self_improvement_engine,
    builder_bridge_engine, validation_engine,
    reinforcement_engine, identity_consolidation_engine,
    identity_influence_engine, identity_memory_engine,
    stabilizer_engine
)
from backend.app.cognition.value_hierarchy import evaluate_values

app = FastAPI()

@app.get("/health")
def health():
    return {
        "brain": "online",
        "identity_influence": True,
        "identity_memory": True
    }

def _brain_cycle():
    world.update({"tick": "loop"})
    meta.run({"event": "cycle"})
    explore.run()

    value_state = evaluate_values()

    identity_influence_state = identity_influence_engine.run()

    intent_state = intent.form_intent({
        "value_state": value_state,
        "identity_influence": identity_influence_state
    })

    decision.run({
        "intent_state": intent_state,
        "identity_influence": identity_influence_state
    })

    execution.run({"plan": {}})

    goal_state = goals.run({
        "goal": intent_state.get("goal"),
        "identity_influence": identity_influence_state
    })

    active_goal = goal_state.get("active_goal")

    mission_state = mission.run({
        "active_goal": active_goal
    }) if active_goal else {"active_mission": None}

    active_mission = mission_state.get("active_mission")

    reality_state = reality.run({
        "mission_id": active_mission.get("id") if active_mission else None,
        "goal_type": active_goal.get("type") if active_goal else None,
        "mission_progress": active_mission.get("progress") if active_mission else 0
    })

    score = reality_state.get("score", 0.5)

    adaptation.run({
        "score": score,
        "goal": active_goal,
        "identity_influence": identity_influence_state
    })

    strategy.run({
        "score": score,
        "identity_influence": identity_influence_state
    })

    coherence_engine.run()
    self_correction_engine.run()
    autonomous_mission_engine.run()

    initiative_state = initiative_engine.run()
    reasoning_state = reasoning_engine.run()
    memory_state = memory_depth_engine.run()
    strategic_adjustment_state = strategic_adjustment_engine.run()
    stability_state = stabilizer_engine.run()
    self_improvement_state = self_improvement_engine.run()
    builder_bridge_state = builder_bridge_engine.run()
    validation_state = validation_engine.run()
    reinforcement_state = reinforcement_engine.run()
    identity_state = identity_consolidation_engine.run()
    identity_memory_state = identity_memory_engine.run()

    return {
        "status": "ok",
        "identity_influence": identity_influence_state,
        "identity_state": identity_state,
        "identity_memory": identity_memory_state,
        "reinforcement_state": reinforcement_state,
        "validation_state": validation_state,
        "initiative_state": initiative_state,
        "reasoning_state": reasoning_state,
        "memory_state": memory_state,
        "strategic_adjustment_state": strategic_adjustment_state,
        "stability_state": stability_state,
        "self_improvement_state": self_improvement_state,
        "builder_bridge_state": builder_bridge_state
    }

@app.post("/api/brain/run")
def brain():
    return _brain_cycle()
