    meta, world, self as legacy_self, self_model,
    explore, decision, goal, execution,
    scheduler, evolution, planning, modification,
    apply, validation, world_model, thought,
    intent, goals, mission
)

from backend.app.cognition.patterns import update_pattern_memory, decay_pattern_memory
from backend.app.cognition.pattern_decision import pattern_bias_decision
from backend.app.cognition.tension import decay_tension_memory, update_tension_memory, get_tension_bias
from backend.app.cognition.intent import form_intent, update_intent_memory
from backend.app.cognition.autonomy import evaluate_self_initiation, record_self_run
from backend.app.cognition.identity_continuity import update_identity
