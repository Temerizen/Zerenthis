from __future__ import annotations
import json, time
from pathlib import Path
from backend.app.cognition import meta, world, self, explore

PATH = Path("backend/data/decision_state.json")

def _default():
    return {
        "history": [],
        "last_decision": None,
        "stats": {
            "total_decisions": 0
        }
    }

def _load():
    if not PATH.exists():
        return _default()
    try:
        d = json.loads(PATH.read_text())
        if "history" not in d:
            d["history"] = []
        if "stats" not in d:
            d["stats"] = {"total_decisions": len(d["history"])}
        return d
    except:
        return _default()

def _save(d):
    PATH.parent.mkdir(parents=True, exist_ok=True)
    PATH.write_text(json.dumps(d, indent=2))

def _score(world_state, meta_state, self_state, explore_state):
    signals = int(world_state.get("signals", 0))
    history = int(meta_state.get("history", 0))
    rate = float(self_state.get("rate", 0.0))
    novelty = 1.0 if explore_state.get("action") else 0.0

    world_score = min(1.0, signals / 10)
    meta_score = min(1.0, history / 10)
    self_score = rate
    explore_score = novelty

    total = round(
        (world_score * 0.25) +
        (meta_score * 0.20) +
        (self_score * 0.35) +
        (explore_score * 0.20),
        3
    )

    return {
        "world_score": world_score,
        "meta_score": meta_score,
        "self_score": self_score,
        "explore_score": explore_score,
        "total_score": total
    }

def decide(world_state=None, meta_state=None, self_state=None, explore_state=None):
    state = _load()

    if world_state is None:
        world_state = world.state()
    if meta_state is None:
        meta_state = meta._load()
        meta_state = {"status": "ok", "history": len(meta_state.get("history", []))}
    if self_state is None:
        self_state = self.state()
    if explore_state is None:
        explore_state = explore.state()
        hist = explore_state.get("history", [])
        last_action = hist[-1]["a"] if hist else None
        explore_state = {"action": last_action, "history": len(hist)}

    scores = _score(world_state, meta_state, self_state, explore_state)

    if self_state.get("rate", 0) < 0.5:
        chosen_action = "stabilize"
        reason = "low_self_score"
    elif world_state.get("signals", 0) >= 5:
        chosen_action = "prioritize_world_signal"
        reason = "high_world_activity"
    elif meta_state.get("history", 0) >= 5 and explore_state.get("action"):
        chosen_action = f"explore:{explore_state['action']}"
        reason = "meta_history_plus_exploration"
    else:
        chosen_action = "continue_cycle"
        reason = "default_progression"

    decision = {
        "timestamp": time.time(),
        "chosen_action": chosen_action,
        "reason": reason,
        "confidence": scores["total_score"],
        "scores": scores
    }

    state["history"].append(decision)
    state["history"] = state["history"][-200:]
    state["last_decision"] = decision
    state["stats"]["total_decisions"] = len(state["history"])

    _save(state)
    return {
        "status": "decision_made",
        "chosen_action": chosen_action,
        "reason": reason,
        "confidence": scores["total_score"],
        "scores": scores,
        "total_decisions": len(state["history"])
    }

def state():
    return _load()

