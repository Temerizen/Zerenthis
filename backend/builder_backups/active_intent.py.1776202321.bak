from __future__ import annotations

import json
import os
import time
from typing import Any, Dict

INTENT_PATH = "backend/data/active_intent.json"

def _load() -> Dict[str, Any]:
    if not os.path.exists(INTENT_PATH):
        return {}
    try:
        with open(INTENT_PATH, "r", encoding="utf-8-sig") as f:
            data = json.load(f)
            return data if isinstance(data, dict) else {}
    except Exception:
        return {}

def _save(data: Dict[str, Any]) -> None:
    os.makedirs(os.path.dirname(INTENT_PATH), exist_ok=True)
    with open(INTENT_PATH, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2)

def get_active_intent() -> Dict[str, Any]:
    return _load()

def update_active_intent(task: str, reason: str, source: str = "brain_patch") -> Dict[str, Any]:
    now = time.time()
    current = _load()

    history = current.get("history", [])
    if not isinstance(history, list):
        history = []

    current.update({
        "task": task,
        "reason": reason,
        "source": source,
        "updated_at": now,
    })

    history.append({
        "task": task,
        "reason": reason,
        "source": source,
        "timestamp": now,
    })

    current["history"] = history[-20:]
    _save(current)
    return current

if __name__ == "__main__":
    print({
        "status": "ok",
        "message": "active_intent_ready",
        "path": INTENT_PATH
    })
