from __future__ import annotations
import json, time
from pathlib import Path

PATH = Path("backend/data/planning_state.json")

def _default():
    return {
        "active_plan": None,
        "history": []
    }

def _load():
    if not PATH.exists():
        return _default()
    try:
        d = json.loads(PATH.read_text())
        return d
    except:
        return _default()

def _save(d):
    PATH.parent.mkdir(parents=True, exist_ok=True)
    PATH.write_text(json.dumps(d, indent=2))

# --- PLAN GENERATOR ---
def _generate_plan(goal_name: str):
    # simple structured planning (expand later)
    steps = [
        f"analyze_{goal_name}",
        f"optimize_{goal_name}",
        f"execute_{goal_name}",
        f"verify_{goal_name}"
    ]

    return {
        "goal": goal_name,
        "steps": steps,
        "current_step": 0,
        "created_at": time.time(),
        "completed": False
    }

# --- ADVANCE PLAN ---
def _advance(plan):
    if plan["completed"]:
        return plan

    plan["current_step"] += 1

    if plan["current_step"] >= len(plan["steps"]):
        plan["completed"] = True

    return plan

def run(goal_selected: dict):
    state = _load()

    goal_name = goal_selected.get("selected")

    plan = state.get("active_plan")

    # if no plan or goal changed → create new plan
    if not plan or plan["goal"] != goal_name or plan.get("completed"):
        plan = _generate_plan(goal_name)

    else:
        plan = _advance(plan)

    state["active_plan"] = plan

    record = {
        "timestamp": time.time(),
        "goal": goal_name,
        "step": plan["current_step"],
        "completed": plan["completed"]
    }

    state["history"].append(record)
    state["history"] = state["history"][-200:]

    _save(state)

    return {
        "status": "plan_updated",
        "goal": goal_name,
        "current_step": plan["current_step"],
        "total_steps": len(plan["steps"]),
        "completed": plan["completed"]
    }

def state():
    return _load()
