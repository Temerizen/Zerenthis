import json
import os
import time
from typing import Any, Dict

DATA_PATH = "backend/data/decision_state.json"
VALUE_PATH = "backend/data/value_system.json"

def _default_state() -> Dict[str, Any]:
    return {
        "history": [],
        "last_action": None,
        "totals": {
            "decisions": 0
        }
    }

def _load_state() -> Dict[str, Any]:
    state = _default_state()
    if not os.path.exists(DATA_PATH):
        return state
    try:
        with open(DATA_PATH, "r", encoding="utf-8") as f:
            loaded = json.load(f)
        if isinstance(loaded, dict):
            state.update(loaded)
    except Exception:
        return state

    if not isinstance(state.get("history"), list):
        state["history"] = []
    if not isinstance(state.get("totals"), dict):
        state["totals"] = {"decisions": 0}
    if not isinstance(state["totals"].get("decisions"), int):
        state["totals"]["decisions"] = 0

    return state

def _save_state(state: Dict[str, Any]) -> None:
    os.makedirs(os.path.dirname(DATA_PATH), exist_ok=True)
    with open(DATA_PATH, "w", encoding="utf-8") as f:
        json.dump(state, f, indent=2)

def _load_value_preferences() -> Dict[str, float]:
    prefs = {
        "exploration": 1.0,
        "efficiency": 1.0,
        "stability": 1.0,
        "novelty": 1.0,
    }

    if not os.path.exists(VALUE_PATH):
        return prefs

    try:
        with open(VALUE_PATH, "r", encoding="utf-8") as f:
            data = json.load(f)
        loaded = data.get("preferences", {})
        if isinstance(loaded, dict):
            for k in prefs:
                v = loaded.get(k)
                if isinstance(v, (int, float)):
                    prefs[k] = float(v)
    except Exception:
        return prefs

    return prefs

def _extract_signal_count(world_state: Dict[str, Any]) -> float:
    signals = world_state.get("signals", 0.0)
    if isinstance(signals, (int, float)):
        return float(signals)
    return 0.0

def _extract_meta_depth(meta_state: Dict[str, Any]) -> float:
    history = meta_state.get("history", 0.0)
    if isinstance(history, (int, float)):
        return float(history)
    return 0.0

def _extract_self_rate(self_state: Dict[str, Any]) -> float:
    rate = self_state.get("rate", 0.5)
    if isinstance(rate, (int, float)):
        return float(rate)
    return 0.5

def _compute_explore_score(explore_state: Dict[str, Any], prefs: Dict[str, float]) -> float:
    chosen = explore_state.get("chosen_strategy", "")
    exploration_drive = explore_state.get("exploration_drive", 0.5)
    success = explore_state.get("success", False)

    if not isinstance(exploration_drive, (int, float)):
        exploration_drive = 0.5

    novelty_bonus = 0.0
    if chosen in ["test_new_action", "probe_unknown"]:
        novelty_bonus = 1.0
    elif chosen in ["modify_known", "stress_test"]:
        novelty_bonus = 0.75
    elif chosen == "repeat_successful":
        novelty_bonus = 0.45

    success_bonus = 0.18 if success else -0.05

    raw = (
        (float(exploration_drive) * prefs["exploration"]) +
        (novelty_bonus * prefs["novelty"]) +
        success_bonus
    ) / 2.0

    return max(0.0, min(1.0, round(raw, 4)))

def _normalize_signal_score(signals: float) -> float:
    return max(0.0, min(1.0, round(signals / 100.0, 4)))

def _normalize_meta_score(history: float) -> float:
    return max(0.0, min(1.0, round(history / 100.0, 4)))

def _normalize_self_score(rate: float, prefs: Dict[str, float]) -> float:
    raw = float(rate) * min(1.2, prefs["stability"])
    return max(0.0, min(1.0, round(raw, 4)))

def decide(
    world_state: Dict[str, Any] | None = None,
    meta_state: Dict[str, Any] | None = None,
    self_state: Dict[str, Any] | None = None,
    explore_state: Dict[str, Any] | None = None,
) -> Dict[str, Any]:
    world_state = world_state or {}
    meta_state = meta_state or {}
    self_state = self_state or {}
    explore_state = explore_state or {}

    state = _load_state()
    prefs = _load_value_preferences()

    world_score = _normalize_signal_score(_extract_signal_count(world_state))
    meta_score = _normalize_meta_score(_extract_meta_depth(meta_state))
    self_score = _normalize_self_score(_extract_self_rate(self_state), prefs)
    explore_score = _compute_explore_score(explore_state, prefs)

    weighted_world = world_score * 0.30
    weighted_meta = meta_score * 0.12
    weighted_self = self_score * 0.18
    weighted_explore = explore_score * 0.40

    total_score = round(
        weighted_world + weighted_meta + weighted_self + weighted_explore,
        4
    )

    if explore_score >= 0.65:
        chosen_action = "pursue_exploration_priority"
        reason = "value_weighted_exploration"
    elif world_score >= 0.95 and explore_score < 0.65:
        chosen_action = "prioritize_world_signal"
        reason = "high_world_activity"
    elif self_score < 0.55:
        chosen_action = "stabilize_internal_state"
        reason = "low_self_stability"
    elif meta_score >= 0.90:
        chosen_action = "analyze_meta_patterns"
        reason = "high_meta_activity"
    else:
        chosen_action = "balanced_progression"
        reason = "weighted_multi_signal"

    confidence = max(
        0.5,
        min(
            0.98,
            round(
                total_score + (0.04 if chosen_action == "pursue_exploration_priority" else 0.0),
                4
            )
        )
    )

    result = {
        "status": "decision_made",
        "chosen_action": chosen_action,
        "reason": reason,
        "confidence": confidence,
        "scores": {
            "world_score": world_score,
            "meta_score": meta_score,
            "self_score": self_score,
            "explore_score": explore_score,
            "total_score": total_score
        },
        "weights": {
            "world": 0.30,
            "meta": 0.12,
            "self": 0.18,
            "explore": 0.40
        },
        "value_preferences": prefs,
        "total_decisions": state["totals"]["decisions"] + 1
    }

    state["last_action"] = chosen_action
    state["totals"]["decisions"] += 1
    state["history"].append({
        "t": time.time(),
        "action": chosen_action,
        "reason": reason,
        "confidence": confidence,
        "scores": result["scores"],
        "preferences": prefs
    })
    state["history"] = state["history"][-200:]

    _save_state(state)
    return result
